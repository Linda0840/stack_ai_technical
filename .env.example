MISTRAL_API_KEY=wSFV43kzPBYKyr3YpDvRcFuka0MutNE2
MISTRAL_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed

CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
SEMANTIC_WEIGHT=0.7
KEYWORD_WEIGHT=0.3

# Embedding tuning
EMBED_BATCH_SIZE=8          # chunks per Mistral API call (default 8, safe for debugging)
EMBED_TIMEOUT_SECONDS=30    # seconds before a single batch call is aborted

# Embedding mode — change this one value to switch modes:
#   skip = store 1024-dim zero-vectors; Mistral API is never called (fast, for debugging)
#   real = call Mistral embedding API; required for semantic search to work
EMBED_MODE=real

# Legacy flag (still respected as a fallback if EMBED_MODE is not set)
# DEBUG_SKIP_EMBEDDINGS=false
